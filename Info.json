{
  "name": "ViewSnap",
  "version": "1.0.0",
  "identifier": "com.viewsnap.plugin",
  "author": { "name": "pounds_1" },
  "description": "Dynamically anchors videos to display edges based on aspect ratio with optional overrides",
  "entry": "main.js",
  "preferenceDefaults": {
    "enabled": true,
    "aspectThreshold": 1.3,
    "edgeMargin": 20,
    "animationDuration": 300,
    "showGuidelines": true
  },
  "permissions": ["browser-window", "system-events"]
}